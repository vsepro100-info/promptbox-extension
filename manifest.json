{
  "manifest_version": 3,
  "name": "PromptBox",
  "version": "0.1.0",
  "description": "Save, organize, search and copy AI prompts instantly.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "PromptBox",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "permissions": ["storage"]
}
